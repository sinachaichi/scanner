# ============================================================
# SECURITY WARNING: Never commit .env to version control.
# Copy this file to .env and fill in real values.
# ============================================================

# Django core — REQUIRED
# Generate with: openssl rand -hex 32
SECRET_KEY=your-secret-key-here

# Django settings
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1

# Fernet key for encrypting GitHub tokens at rest — REQUIRED
# Generate with:
#   python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
FIELD_ENCRYPTION_KEY=your-fernet-key-here

# Telegram API credentials — OPTIONAL (skip to use HTTP mirrors only)
# Obtain from https://my.telegram.org → API development tools
# NEVER share these values. Treat them like passwords.
TELEGRAM_API_ID=
TELEGRAM_API_HASH=

# xray binary path (default: ./xray)
XRAY_PATH=./xray

# Max simultaneous xray speed tests (default: 5). Higher = faster scan but more RAM/CPU.
MAX_CONCURRENT_XRAY=5

# Celery / Redis
CELERY_BROKER_URL=redis://localhost:6379/0

# Port for Gunicorn / CSRF trusted origin
RANDOM_PORT=30080

# Logging level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
